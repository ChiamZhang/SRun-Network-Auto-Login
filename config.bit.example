# BIT（北京理工大学）配置示例
# 复制本文件为 config 后填写（config 已在 .gitignore，勿提交到公开仓库）

USERNAME="你的学号"
PASSWORD="你的密码"
ACID="8"
# BIT 门户 ac_id：用浏览器完成一次校园网登录，看地址栏或开发者工具
#   http://10.0.0.55/srun_portal_pc?ac_id=??&...
# 或 Network 里请求的 ac_id=。不同宿舍/网络区域可能不同，务必按自己环境填写。

# ---------- BIT 网关参数 ----------
# BIT 使用 http + 10.0.0.55 内网地址 + bit theme
SRUN_SCHEME="http"
SRUN_HOST="10.0.0.55"
SRUN_THEME="bit"
SRUN_REF_URL="10.0.0.55"
SRUN_DOMAIN=""

# 或直接指定完整 URL（优先级更高）：
# SRUN_LOGIN_PAGE_URL="http://10.0.0.55/srun_portal_pc?ac_id=8&theme=bit"
# SRUN_GET_CHALLENGE_URL="http://10.0.0.55/cgi-bin/get_challenge"
# SRUN_PORTAL_API_URL="http://10.0.0.55/cgi-bin/srun_portal"
# SRUN_RAD_USER_INFO_URL="http://10.0.0.55/cgi-bin/rad_user_info"

# ---------- 可选 ----------
# protect-connect.sh 检测间隔（秒），不小于 60；不设则默认 3600
PROTECT_INTERVAL="3600"

# 若网关要求向 get_challenge 传固定本机 IP 再取消注释
# IPADDR="10.x.x.x"

# 临时覆盖可用环境变量: BUAA_USERNAME BUAA_PASSWORD BUAA_ACID（名义上是BUAA但实际会被读取）
# BUAA_DEBUG=1
# 临时覆盖检测间隔: PROTECT_INTERVAL=1800 bash protect-connect.sh
